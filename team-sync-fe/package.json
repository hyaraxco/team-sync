{
  "name": "teamsync-fe",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.{js,vue}'",
    "format:check": "prettier --check 'src/**/*.{js,vue}'",
    "test:guards": "vitest run src/tests/router/routerGuard.integration.test.js src/tests/router/featureGuardMatrix.test.js src/tests/admin/components/Sidebar.smoke.test.js src/tests/admin/components/Header.smoke.test.js src/tests/admin/components/NotificationPanel.smoke.test.js src/tests/admin/dashboard/QuickActions.smoke.test.js src/tests/admin/payroll/PayrollDashboard.smoke.test.js src/tests/admin/payroll/PayrollCreate.smoke.test.js src/tests/admin/payroll/PayrollDetail.smoke.test.js src/tests/admin/payroll/PayrollSettings.smoke.test.js src/tests/employee/EmployeeProfile.smoke.test.js src/tests/employee/MyAttendance.smoke.test.js src/tests/employee/MyPayslips.smoke.test.js src/tests/employee/PayslipDetail.smoke.test.js src/tests/employee/EmployeeTeam.smoke.test.js",
    "test:watch": "vitest",
    "tw:watch": "tailwindcss -i ./src/assets/css/input.css -o ./src/assets/css/main.css --watch",
    "e2e:install": "playwright install",
    "e2e:prepare:be": "bash ./scripts/e2e-prepare-be.sh",
    "e2e:ui": "E2E_FE_BASE_URL=${E2E_FE_BASE_URL:-http://127.0.0.1:4173} VITE_API_BASE_URL=${VITE_API_BASE_URL:-http://127.0.0.1:8000/api/v1} playwright test",
    "e2e": "bun run e2e:prepare:be && bun run e2e:ui",
    "e2e:report": "playwright show-report"
  },
  "dependencies": {
    "apexcharts": "^5.3.5",
    "axios": "^1.12.2",
    "caniuse-lite": "^1.0.30001791",
    "js-cookie": "^3.0.5",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lodash": "^4.17.21",
    "lucide": "^0.544.0",
    "lucide-vue-next": "^0.544.0",
    "luxon": "^3.7.2",
    "pinia": "^3.0.3",
    "sortablejs": "^1.15.6",
    "vue": "^3.5.18",
    "vue-draggable-next": "^2.3.0",
    "vue-router": "^4.5.1",
    "vue3-apexcharts": "^1.8.0",
    "vue3-emoji-picker": "^1.1.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitejs/plugin-vue-jsx": "^5.0.1",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.10.27",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.6",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.17",
    "typescript-eslint": "^8.59.2",
    "vite": "^7.0.6",
    "vite-plugin-vue-devtools": "^8.0.0",
    "vitest": "^4.1.1"
  }
}
